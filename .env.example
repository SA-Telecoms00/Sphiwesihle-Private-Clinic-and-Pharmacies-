# ----------------------------------------------------------------------------
# Sphiwesihle Private Clinics & Pharmacies — environment variables
# Copy to `.env.local` for local dev, or set these in Plesk:
#   Websites & Domains → Node.js → Custom environment variables
# All are OPTIONAL: the site runs without them (forms log server-side; the
# deposit flow stays hidden).
# ----------------------------------------------------------------------------

# Canonical site URL (used for metadata, sitemap, robots, JSON-LD, Paystack callback)
# IMPORTANT: NEXT_PUBLIC_ vars are inlined at BUILD time — set this BEFORE
# running `npm run build` on the server, not just at runtime.
NEXT_PUBLIC_SITE_URL="https://sphiwesihleclinics.co.za"

# --- Email delivery (Resend) -------------------------------------------------
# When RESEND_API_KEY is set, booking + enquiry forms email the clinic inbox.
# Without it, submissions are validated and logged server-side (nothing lost).
RESEND_API_KEY=""
# Verified sender (must be a domain you've verified in Resend)
RESEND_FROM="Sphiwesihle Clinic <bookings@sphiwesihleclinics.co.za>"
# Where form submissions are delivered (defaults to the clinic email in content)
CONTACT_INBOX="info@sphiwesihleclinics.co.za"

# --- Payments (Paystack) -----------------------------------------------------
# When PAYSTACK_SECRET_KEY is set, the optional deposit flow on /book activates.
PAYSTACK_SECRET_KEY=""
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=""
# Appointment deposit amount in ZAR (major units)
PAYSTACK_DEPOSIT_AMOUNT="150"
